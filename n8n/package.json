{
  "name": "n8n-nodes-mcp-sales-agent",
  "version": "1.0.0",
  "description": "n8n node for MCP Sales Agent — call intelligence, pipeline updates, follow-ups, and coaching via n8n workflows.",
  "keywords": [
    "n8n",
    "n8n-node",
    "mcp",
    "sales",
    "crm",
    "ai-agent"
  ],
  "license": "MIT",
  "homepage": "https://github.com/developers-universe-1/agentic-sales-engine",
  "author": {
    "name": "developers-universe-1",
    "email": ""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developers-universe-1/agentic-sales-engine.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/McpSalesAgentApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/McpSalesAgent/McpSalesAgent.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
